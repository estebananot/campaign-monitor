# API externa (CoinGecko - API pública sin key requerida)
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_TOP_N=10

# Umbrales de evaluación
THRESHOLD_WARNING=2.5
THRESHOLD_CRITICAL=1.0

# N8N Webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook/campaign-monitor

# LLM — elegir un proveedor
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
# ANTHROPIC_API_KEY=sk-ant-xxxx

# Redis (solo para diferencial BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
JOB_INTERVAL_MINUTES=5
